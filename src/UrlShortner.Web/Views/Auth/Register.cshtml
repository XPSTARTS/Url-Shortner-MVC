@* src/UrlShortner.Web/Views/Auth/Register.cshtml *@
@model UrlShortner.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2>🔗 URL Shortner</h2>
                    <p class="text-muted">Create your account</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text">📧</span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text">🔒</span>
                            <input asp-for="Password" class="form-control" placeholder="Min. 8 characters" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text">🔒</span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        Create Account
                    </button>
                </form>

                <div class="text-center mt-3">
                    <p class="mb-0">Already have an account? <a asp-action="Login">Sign in</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}