@model UrlShortner.Web.Models.ShortenUrlViewModel
@{
    ViewData["Title"] = "URL Shortner";
}
<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Shorten Your Links</h1>
        <p class="lead text-muted">Fast, simple, and free URL shortener with advanced analytics.</p>
    </div>
    
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-body p-4">
                    <form asp-controller="Url" asp-action="Create" method="post">
                        <div class="mb-3">
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">🔗</span>
                                <input asp-for="OriginalUrl" class="form-control" 
                                       placeholder="Paste your long URL here..." />
                            </div>
                            <span asp-validation-for="OriginalUrl" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <div class="input-group">
                                <span class="input-group-text">domain.com/</span>
                                <input asp-for="CustomAlias" class="form-control" 
                                       placeholder="custom-alias (optional)" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Shorten URL
                        </button>
                    </form>
                </div>
            </div>
            @if (!User.Identity.IsAuthenticated)
            {
                <div class="text-center mt-3">
                    <p>
                        <a asp-controller="Auth" asp-action="Register">Create an account</a> 
                        to track your links and view analytics.
                    </p>
                </div>
            }
        </div>
    </div>
    
    <div class="row mt-5 text-center">
        <div class="col-md-4 mb-3">
            <h3>⚡ Fast</h3>
            <p class="text-muted">Instant redirects with Redis caching</p>
        </div>
        <div class="col-md-4 mb-3">
            <h3>📊 Analytics</h3>
            <p class="text-muted">Track clicks, referrers, and locations</p>
        </div>
        <div class="col-md-4 mb-3">
            <h3>🔒 Secure</h3>
            <p class="text-muted">2FA authentication for your account</p>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
