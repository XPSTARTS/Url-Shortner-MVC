@model UrlShortner.Domain.Entities.User
@{
    ViewData["Title"] = "Profile";
}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h2 class="mb-4">Profile</h2>
                    
                    <div class="mb-3">
                        <label class="text-muted small">User ID</label>
                        <p class="fw-bold">#@Model.Id</p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small">Email</label>
                        <p class="fw-bold">@Model.Email</p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small">Email Verified</label>
                        <p>
                            @if (Model.EmailVerified)
                            {
                                <span class="badge bg-success">Verified ✅</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Pending ⚠️</span>
                            }
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small">Member Since</label>
                        <p>@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="text-muted small">Last Login</label>
                        <p>@(Model.LastLoginAt?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")</p>
                    </div>
                    
                    <hr />
                    
                    <h5>URL Statistics</h5>
                    <div class="row mt-3">
                        <div class="col-4 text-center">
                            <h3 class="text-primary">@ViewBag.TotalUrls</h3>
                            <small class="text-muted">Total URLs</small>
                        </div>
                        <div class="col-4 text-center">
                            <h3 class="text-success">@ViewBag.TotalClicks.ToString("N0")</h3>
                            <small class="text-muted">Total Clicks</small>
                        </div>
                        <div class="col-4 text-center">
                            <h3 class="text-info">@ViewBag.ActiveUrls</h3>
                            <small class="text-muted">Active</small>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
