@{
    ViewData["Title"] = "Link Not Found";
    Layout = "_Layout";
}
<div class="container mt-5 text-center">
    <div class="py-5">
        <h1 class="display-1 text-muted">404</h1>
        <h2 class="mb-4">Link Not Found</h2>
        <p class="lead text-muted mb-4">The short link you followed doesn't exist or has been removed.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            Go to Homepage
        </a>
    </div>
</div>
