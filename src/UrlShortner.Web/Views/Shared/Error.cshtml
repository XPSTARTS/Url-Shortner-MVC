@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}
<div class="container mt-5 text-center">
    <div class="py-5">
        <h1 class="display-1 text-muted">Oops!</h1>
        <h2 class="mb-4">Something went wrong</h2>
        <p class="lead text-muted mb-4">An unexpected error occurred. Please try again later.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            Go to Homepage
        </a>
    </div>
</div>
